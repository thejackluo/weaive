# Backend API Configuration
#
# ⚠️  IMPORTANT: Use host machine IP address, NOT localhost!
# - localhost on mobile device = the device itself (won't reach your computer)
# - Use your computer's local IP: 192.168.x.x or 10.0.x.x
#
# How to find your IP:
# - Mac/Linux: ifconfig | grep "inet " | grep -v 127.0.0.1
# - Windows: ipconfig | findstr IPv4
#
# Examples:
# - Mobile/Simulator: API_BASE_URL=http://192.168.1.100:8002
# - Web browser only: API_BASE_URL=http://localhost:8002
# - Different worktrees: Use different ports (8001, 8002, etc.)
#
API_BASE_URL=http://192.168.1.100:8000
# Weave Mobile Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Development Settings
# Set to true to bypass auth guards and go directly to main app (tabs)
# ONLY use this for testing navigation during development
# Default: false (auth guards enabled)
EXPO_PUBLIC_DEV_SKIP_AUTH=false

# API Configuration (if using local development server)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
