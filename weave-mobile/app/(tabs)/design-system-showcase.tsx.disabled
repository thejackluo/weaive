        contentContainerStyle={dynamicStyles.contentContainer}
        showsVerticalScrollIndicator={false}
      >
        {/* FOUNDATIONS TAB */}
        {activeTab === 'foundations' && (
          <View style={dynamicStyles.sectionGap}>
            <Section title="Color Palette" spacing={spacing}>
              <View style={dynamicStyles.colorPaletteRow}>
                <ColorSwatch color={colors?.accent?.[500]} label="Accent" spacing={spacing} radius={radius} />
                <ColorSwatch color={colors?.violet?.[500]} label="Violet (AI)" spacing={spacing} radius={radius} />
                <ColorSwatch color={colors?.amber?.[500]} label="Amber" spacing={spacing} radius={radius} />
                <ColorSwatch color={colors?.emerald?.[500]} label="Emerald" spacing={spacing} radius={radius} />
                <ColorSwatch color={colors?.rose?.[500]} label="Rose" spacing={spacing} radius={radius} />
                <ColorSwatch color={colors?.blue?.[500]} label="Blue" spacing={spacing} radius={radius} />
              </View>
            </Section>

            <Section title="Semantic Colors" spacing={spacing}>
              <Card variant="default" padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <View style={dynamicStyles.lightBgDemo}>
                    <Text style={{ color: colors?.dark?.[900] }}>Dark text on light background ✓</Text>
                  </View>
                  <View style={dynamicStyles.darkBgDemo}>
                    <Text style={{ color: colors?.light?.[100] }}>Light text on dark background ✓</Text>
                  </View>
                </View>
              </Card>
            </Section>

            <Section title="Typography Scale" spacing={spacing}>
              <Card variant="glass" padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <Text style={{ fontSize: typography?.fontSize?.['6xl'], fontWeight: '700' }}>6XL - 60px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.['5xl'], fontWeight: '700' }}>5XL - 48px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.['4xl'], fontWeight: '700' }}>4XL - 36px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.['3xl'], fontWeight: '700' }}>3XL - 30px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.['2xl'], fontWeight: '600' }}>2XL - 24px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.xl, fontWeight: '600' }}>XL - 20px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.lg }}>LG - 18px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.base }}>Base - 16px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.sm }}>SM - 14px</Text>
                  <Text style={{ fontSize: typography?.fontSize?.xs }}>XS - 12px</Text>
                </View>
              </Card>
            </Section>

            <Section title="Spacing System" spacing={spacing}>
              <Card padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: spacing?.[2] }}>
                    <View style={{ width: spacing?.[1], height: spacing?.[4], backgroundColor: colors?.accent?.[500] }} />
                    <Caption>1 = {spacing?.[1]}px</Caption>
                  </View>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: spacing?.[2] }}>
                    <View style={{ width: spacing?.[2], height: spacing?.[4], backgroundColor: colors?.accent?.[500] }} />
                    <Caption>2 = {spacing?.[2]}px</Caption>
                  </View>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: spacing?.[2] }}>
                    <View style={{ width: spacing?.[4], height: spacing?.[4], backgroundColor: colors?.accent?.[500] }} />
                    <Caption>4 = {spacing?.[4]}px</Caption>
                  </View>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: spacing?.[2] }}>
                    <View style={{ width: spacing?.[6], height: spacing?.[4], backgroundColor: colors?.accent?.[500] }} />
                    <Caption>6 = {spacing?.[6]}px</Caption>
                  </View>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: spacing?.[2] }}>
                    <View style={{ width: spacing?.[8], height: spacing?.[4], backgroundColor: colors?.accent?.[500] }} />
                    <Caption>8 = {spacing?.[8]}px</Caption>
                  </View>
                </View>
              </Card>
            </Section>

            <Section title="Border Radius" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                <View style={{ flexDirection: 'row', gap: spacing?.[3], flexWrap: 'wrap' }}>
                  <View style={dynamicStyles.gridItem}>
                    <View style={{ width: 80, height: 80, backgroundColor: colors?.accent?.[500], borderRadius: radius?.sm }} />
                    <Caption style={dynamicStyles.marginTop2}>SM - {radius?.sm}px</Caption>
                  </View>
                  <View style={dynamicStyles.gridItem}>
                    <View style={{ width: 80, height: 80, backgroundColor: colors?.accent?.[500], borderRadius: radius?.md }} />
                    <Caption style={dynamicStyles.marginTop2}>MD - {radius?.md}px</Caption>
                  </View>
                  <View style={dynamicStyles.gridItem}>
                    <View style={{ width: 80, height: 80, backgroundColor: colors?.accent?.[500], borderRadius: radius?.lg }} />
                    <Caption style={dynamicStyles.marginTop2}>LG - {radius?.lg}px</Caption>
                  </View>
                  <View style={dynamicStyles.gridItem}>
                    <View style={{ width: 80, height: 80, backgroundColor: colors?.accent?.[500], borderRadius: radius?.xl }} />
                    <Caption style={dynamicStyles.marginTop2}>XL - {radius?.xl}px</Caption>
                  </View>
                </View>
              </View>
            </Section>

            <Section title="Glassmorphism Effects" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                <Card variant="glass" padding="spacious">
                  <Label>Glass Card</Label>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Standard blur • Opal-inspired
                  </Caption>
                </Card>

                <Card variant="elevated" padding="spacious">
                  <Label>Glass Elevated</Label>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Stronger blur • Shadow elevation
                  </Caption>
                </Card>

                <Card variant="ai" padding="spacious">
                  <Label color="ai">Glass AI</Label>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Violet-tinted • AI features
                  </Caption>
                </Card>

                <Card variant="success" padding="spacious">
                  <Label color="success">Glass Success</Label>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Emerald-tinted • Achievements
                  </Caption>
                </Card>
              </View>
            </Section>
          </View>
        )}

        {/* TYPOGRAPHY TAB */}
        {activeTab === 'typography' && (
          <View style={dynamicStyles.sectionGap}>
            <Section title="Text Components (13 Types)" spacing={spacing}>
              <Card variant="default" padding="spacious">
                <View style={dynamicStyles.gap3}>
                  <Heading>Heading Component</Heading>
                  <Title>Title Component</Title>
                  <Subtitle>Subtitle Component</Subtitle>
                  <Body>Body Component - Default text</Body>
                  <BodySmall>BodySmall Component - Smaller body text</BodySmall>
                  <Caption color="muted">Caption Component - Helper text</Caption>
                  <Label color="primary">Label Component - Form labels</Label>
                  <Link>Link Component - Clickable text</Link>
                  <Mono>Mono Component - Monospace code</Mono>
                </View>
              </Card>
            </Section>

            <Section title="Text Variants" spacing={spacing}>
              <Card variant="glass" padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <Text variant="displayLg">Display Large - Hero text</Text>
                  <Text variant="displayMd">Display Medium - Section headers</Text>
                  <Text variant="textXl">Text XL - Large paragraphs</Text>
                  <Text variant="textLg">Text Large - Prominent text</Text>
                  <Text variant="textBase">Text Base - Default body</Text>
                  <Text variant="textSm">Text Small - Secondary info</Text>
                  <Text variant="textXs">Text Extra Small - Captions</Text>
                </View>
              </Card>
            </Section>

            <Section title="Font Weights" spacing={spacing}>
              <Card variant="elevated" padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <Text weight="regular">Regular (400) - Default</Text>
                  <Text weight="medium">Medium (500) - Emphasis</Text>
                  <Text weight="semibold">Semibold (600) - Headings</Text>
                  <Text weight="bold">Bold (700) - Strong emphasis</Text>
                </View>
              </Card>
            </Section>

            <Section title="Text Colors" spacing={spacing}>
              <Card padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <Text color="primary">Primary - Main text color</Text>
                  <Text color="secondary">Secondary - Subdued text</Text>
                  <Text color="muted">Muted - Helper text</Text>
                  <Text color="disabled">Disabled - Inactive text</Text>
                  <Text color="ai">AI - Violet for AI features</Text>
                  <Text color="success">Success - Positive actions</Text>
                  <Text color="error">Error - Warnings and errors</Text>
                  <Text color="warning">Warning - Caution messages</Text>
                </View>
              </Card>
            </Section>

            <Section title="Contrast Examples" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                {/* Light background examples */}
                <Card variant="default" padding="spacious">
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    ✓ Light card with dark text (proper contrast)
                  </Caption>
                  <Body style={dynamicStyles.marginTop2}>
                    Dark text on light background ensures readability
                  </Body>
                </Card>

                {/* Dark background examples */}
                <View style={dynamicStyles.darkBgDemo}>
                  <Caption style={{ color: colors?.dark?.[400], marginBottom: spacing?.[1] }}>
                    ✓ Dark background with light text (proper contrast)
                  </Caption>
                  <Text style={{ color: colors?.light?.[100], marginTop: spacing?.[2] }}>
                    Light text on dark background ensures readability
                  </Text>
                </View>
              </View>
            </Section>
          </View>
        )}

        {/* BUTTONS TAB */}
        {activeTab === 'buttons' && (
          <View style={dynamicStyles.sectionGap}>
            <Section title="Button Variants (7 Types)" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                <PrimaryButton onPress={() => {}}>Primary Button</PrimaryButton>
                <SecondaryButton onPress={() => {}}>Secondary Button</SecondaryButton>
                <GhostButton onPress={() => {}}>Ghost Button</GhostButton>
                <DestructiveButton onPress={() => {}}>Destructive Button</DestructiveButton>
                <AIButton onPress={() => {}}>AI Button</AIButton>
                <Button variant="default" onPress={() => {}}>Default Button</Button>
              </View>
            </Section>

            <Section title="Button Sizes" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                <PrimaryButton size="sm" onPress={() => {}}>Small Button</PrimaryButton>
                <PrimaryButton size="md" onPress={() => {}}>Medium Button (Default)</PrimaryButton>
                <PrimaryButton size="lg" onPress={() => {}}>Large Button</PrimaryButton>
              </View>
            </Section>

            <Section title="Button States" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                <PrimaryButton onPress={() => {}}>Default State</PrimaryButton>
                <PrimaryButton disabled onPress={() => {}}>Disabled State</PrimaryButton>
                <PrimaryButton loading onPress={() => {}}>Loading State</PrimaryButton>
              </View>
            </Section>

            <Section title="Icon Buttons" spacing={spacing}>
              <View style={dynamicStyles.buttonGrid}>
                <IconButton icon="+" onPress={() => {}} />
                <IconButton icon="×" onPress={() => {}} variant="secondary" />
                <IconButton icon="✓" onPress={() => {}} variant="ai" />
                <IconButton icon="→" onPress={() => {}} size="sm" />
                <IconButton icon="←" onPress={() => {}} size="lg" />
              </View>
            </Section>

            <Section title="Button Contrast Check" spacing={spacing}>
              <Card padding="spacious">
                <View style={dynamicStyles.gap2}>
                  <Caption color="muted">✓ Primary button has dark text on light background</Caption>
                  <Caption color="muted">✓ AI button has proper violet contrast</Caption>
                  <Caption color="muted">✓ Destructive button has appropriate warning colors</Caption>
                  <Caption color="muted">✓ Ghost button adapts to background</Caption>
                </View>
              </Card>
            </Section>
          </View>
        )}

        {/* CARDS TAB */}
        {activeTab === 'cards' && (
          <View style={dynamicStyles.sectionGap}>
            <Section title="Basic Card Variants" spacing={spacing}>
              <View style={dynamicStyles.gap3}>
                <Card variant="default">
                  <Body>Default Card</Body>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Standard with border
                  </Caption>
                </Card>

                <GlassCard>
                  <Body>Glass Card ✨</Body>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Opal-inspired transparency
                  </Caption>
                </GlassCard>

                <ElevatedCard>
                  <Body>Elevated Card</Body>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Subtle shadow elevation
                  </Caption>
                </ElevatedCard>

                <Card variant="outlined">
                  <Body>Outlined Card</Body>
                  <Caption color="muted" style={dynamicStyles.marginTop1}>
                    Border-only minimal style
                  </Caption>
