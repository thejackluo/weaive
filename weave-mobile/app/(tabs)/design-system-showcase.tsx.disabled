/**
 * Weave Design System Showcase
 *
 * COMPREHENSIVE showcase of ALL 70+ design system components
 * - Bottom navigation (mobile app pattern)
 * - 8 comprehensive tabs
 * - ALL components with ALL variants
 * - Proper contrast throughout (dark text on light, light text on dark)
 */

import React, { useState } from 'react';
import {
  View,
  ScrollView,
  StyleSheet,
  Pressable,
  Text as RNText,
} from 'react-native';
import { SafeAreaView } from 'react-native-safe-area-context';
import {
  // Theme
  ThemeProvider,
  useTheme,

  // Text Components (13)
  Text,
  AnimatedText,
  Heading,
  Title,
  Subtitle,
  Body,
  BodySmall,
  Caption,
  Label,
  Link,
  Mono,

  // Button Components (7)
  Button,
  PrimaryButton,
  SecondaryButton,
  GhostButton,
  DestructiveButton,
  AIButton,
  IconButton,

  // Card Components (7)
  Card,
  GlassCard,
  ElevatedCard,
  AICard,
  SuccessCard,
  NeedleCard,
  InsightCard,

  // Input Components (3) - COMMENTED OUT: Not yet implemented in mobile design system
  // Input,
  // TextArea,
  // SearchInput,

  // Checkbox Components (2)
  Checkbox,
  BindCheckbox,

  // Badge Components (6)
  Badge,
  CountBadge,
  StatusDot,
  StreakBadge,
  AIBadge,
  ConsistencyBadge,

  // Specialized Cards (2)
  BindCard,
  CaptureCard,

  // Progress Components (2)
  ProgressBar,
  CircularProgress,

  // Heatmap (1)
  ConsistencyHeatmap,

  // Navigation Components (3)
  BottomTabBar,
  HeaderBar,
  BackButton,

  // Overlay Components (3)
  Modal,
  BottomSheet,
  Toast,

  // Timer (1)
  Timer,

  // Skeleton Loaders (8)
  Skeleton,
  SkeletonText,
  SkeletonAvatar,
  SkeletonCard,
  SkeletonListItem,
  SkeletonBindCard,
  SkeletonStatCard,
  SkeletonProgressCard,

  // Empty State Components (9)
  EmptyState,
  EmptyGoals,
  EmptyBinds,
  EmptyCaptures,
  EmptyJournal,
  EmptySearch,
  EmptyNotifications,
  ErrorState,
  NoConnectionState,
  ComingSoonState,

  // Avatar Components (3)
  Avatar,
  AvatarGroup,
  AvatarWithName,

  // Stat Card Components (4)
  StatCard,
  StatCardGrid,
  MiniStatCard,
  ProgressStatCard,
} from '../../src/design-system';

type TabId = 'foundations' | 'typography' | 'buttons' | 'cards' | 'inputs' | 'status' | 'specialty' | 'overlays';

function ShowcaseContent() {
  const { colors, spacing, radius, typography } = useTheme();

  // ============================================
  // ASSERTION CHECKS - Identify undefined components
  // ============================================
  const assertDefined = (name: string, v: any) => {
    if (!v) throw new Error(`[ShowcaseContent] ${name} is undefined (import/export mismatch)`);
    if (typeof v !== 'function' && typeof v !== 'object') {
      throw new Error(`[ShowcaseContent] ${name} is weird type: ${typeof v}`);
    }
  };

  // Text Components
  assertDefined("Text", Text);
  assertDefined("AnimatedText", AnimatedText);
  assertDefined("Heading", Heading);
  assertDefined("Title", Title);
  assertDefined("Subtitle", Subtitle);
  assertDefined("Body", Body);
  assertDefined("BodySmall", BodySmall);
  assertDefined("Caption", Caption);
  assertDefined("Label", Label);
  assertDefined("Link", Link);
  assertDefined("Mono", Mono);

  // Button Components
  assertDefined("Button", Button);
  assertDefined("PrimaryButton", PrimaryButton);
  assertDefined("SecondaryButton", SecondaryButton);
  assertDefined("GhostButton", GhostButton);
  assertDefined("DestructiveButton", DestructiveButton);
  assertDefined("AIButton", AIButton);
  assertDefined("IconButton", IconButton);

  // Card Components
  assertDefined("Card", Card);
  assertDefined("GlassCard", GlassCard);
  assertDefined("ElevatedCard", ElevatedCard);
  assertDefined("AICard", AICard);
  assertDefined("SuccessCard", SuccessCard);
  assertDefined("NeedleCard", NeedleCard);
  assertDefined("InsightCard", InsightCard);

  // Input Components - COMMENTED OUT: Not yet implemented
  // assertDefined("Input", Input);
  // assertDefined("TextArea", TextArea);
  // assertDefined("SearchInput", SearchInput);

  // Checkbox Components
  assertDefined("Checkbox", Checkbox);
  assertDefined("BindCheckbox", BindCheckbox);

  // Badge Components
  assertDefined("Badge", Badge);
  assertDefined("CountBadge", CountBadge);
  assertDefined("StatusDot", StatusDot);
  assertDefined("StreakBadge", StreakBadge);
  assertDefined("AIBadge", AIBadge);
  assertDefined("ConsistencyBadge", ConsistencyBadge);

  // Specialized Cards
  assertDefined("BindCard", BindCard);
  assertDefined("CaptureCard", CaptureCard);

  // Progress Components
  assertDefined("ProgressBar", ProgressBar);
  assertDefined("CircularProgress", CircularProgress);

  // Heatmap
  assertDefined("ConsistencyHeatmap", ConsistencyHeatmap);

  // Navigation Components
  assertDefined("BottomTabBar", BottomTabBar);
  assertDefined("HeaderBar", HeaderBar);
  assertDefined("BackButton", BackButton);

  // Overlay Components
  assertDefined("Modal", Modal);
  assertDefined("BottomSheet", BottomSheet);
  assertDefined("Toast", Toast);

  // Timer
  assertDefined("Timer", Timer);

  // Skeleton Loaders
  assertDefined("Skeleton", Skeleton);
  assertDefined("SkeletonText", SkeletonText);
  assertDefined("SkeletonAvatar", SkeletonAvatar);
  assertDefined("SkeletonCard", SkeletonCard);
  assertDefined("SkeletonListItem", SkeletonListItem);
  assertDefined("SkeletonBindCard", SkeletonBindCard);
  assertDefined("SkeletonStatCard", SkeletonStatCard);
  assertDefined("SkeletonProgressCard", SkeletonProgressCard);

  // Empty State Components
  assertDefined("EmptyState", EmptyState);
  assertDefined("EmptyGoals", EmptyGoals);
  assertDefined("EmptyBinds", EmptyBinds);
  assertDefined("EmptyCaptures", EmptyCaptures);
  assertDefined("EmptyJournal", EmptyJournal);
  assertDefined("EmptySearch", EmptySearch);
  assertDefined("EmptyNotifications", EmptyNotifications);
  assertDefined("ErrorState", ErrorState);
  assertDefined("NoConnectionState", NoConnectionState);
  assertDefined("ComingSoonState", ComingSoonState);

  // Avatar Components
  assertDefined("Avatar", Avatar);
  assertDefined("AvatarGroup", AvatarGroup);
  assertDefined("AvatarWithName", AvatarWithName);

  // Stat Card Components
  assertDefined("StatCard", StatCard);
  assertDefined("StatCardGrid", StatCardGrid);
  assertDefined("MiniStatCard", MiniStatCard);
  assertDefined("ProgressStatCard", ProgressStatCard);

  console.log("✅ All 73 components are defined!");
  // ============================================

  // Guard: Return early if theme is not available
  if (!colors || !spacing || !radius || !typography) {
    return (
      <SafeAreaView style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#000' }}>
        <RNText style={{ color: '#fff' }}>Loading theme...</RNText>
      </SafeAreaView>
    );
  }

  const [activeTab, setActiveTab] = useState<TabId>('foundations');

  const tabs: Array<{ id: TabId; label: string; icon?: string }> = [
    { id: 'foundations', label: 'Foundations' },
    { id: 'typography', label: 'Typography' },
    { id: 'buttons', label: 'Buttons' },
    { id: 'cards', label: 'Cards' },
    { id: 'inputs', label: 'Inputs' },
    { id: 'status', label: 'Status' },
    { id: 'specialty', label: 'Specialty' },
    { id: 'overlays', label: 'Overlays' },
  ];

  // Dynamic styles using StyleSheet (bypasses react-native-css)
  const dynamicStyles = StyleSheet.create({
    // Container
    container: {
      flex: 1,
      backgroundColor: colors?.background?.primary,
    },

    // Header
    header: {
      padding: spacing?.[4],
      alignItems: 'center' as const,
      borderBottomWidth: 1,
      borderBottomColor: colors?.border?.muted,
    },
    headerCaption: {
      marginTop: spacing?.[2],
    },

    // Content
    contentScrollView: {
      flex: 1,
    },
    contentContainer: {
      padding: spacing?.[4],
      paddingBottom: spacing?.[24], // Extra padding for bottom nav
    },

    // Bottom Navigation Bar (FIXED AT BOTTOM)
    bottomNavBar: {
      position: 'absolute' as const,
      bottom: 0,
      left: 0,
      right: 0,
      backgroundColor: colors?.background?.secondary,
      borderTopWidth: 1,
      borderTopColor: colors?.border?.muted,
      paddingBottom: spacing?.[2], // Safe area padding
    },
    bottomNavScrollView: {
      paddingHorizontal: spacing?.[2],
      paddingVertical: spacing?.[2],
    },
    bottomNavContent: {
      flexDirection: 'row' as const,
      gap: spacing?.[2],
    },

    // Tab buttons
    tabButton: {
      paddingHorizontal: spacing?.[4],
      paddingVertical: spacing?.[3],
      borderRadius: radius?.md,
      minWidth: 90,
      alignItems: 'center' as const,
    },
    tabButtonActive: {
      backgroundColor: colors?.accent?.[500],
    },
    tabButtonInactive: {
      backgroundColor: 'transparent' as const,
    },
    tabTextActive: {
      color: colors?.dark?.[900], // Dark text on light accent bg
      fontSize: 13,
      fontWeight: '600' as const,
    },
    tabTextInactive: {
      color: colors?.text?.secondary,
      fontSize: 13,
      fontWeight: '500' as const,
    },

    // Section styles
    sectionGap: {
      gap: spacing?.[6],
    },
    section: {
      gap: spacing?.[3],
    },

    // Spacing helpers
    marginTop1: {
      marginTop: spacing?.[1],
    },
    marginTop2: {
      marginTop: spacing?.[2],
    },
    marginTop3: {
      marginTop: spacing?.[3],
    },
    marginTop4: {
      marginTop: spacing?.[4],
    },
    gap1: {
      gap: spacing?.[1],
    },
    gap2: {
      gap: spacing?.[2],
    },
    gap3: {
      gap: spacing?.[3],
    },
    gap4: {
      gap: spacing?.[4],
    },
    padding2: {
      padding: spacing?.[2],
    },
    padding3: {
      padding: spacing?.[3],
    },
    padding4: {
      padding: spacing?.[4],
    },

    // Color palette
    colorPaletteRow: {
      flexDirection: 'row' as const,
      gap: spacing?.[3],
      flexWrap: 'wrap' as const,
    },

    // Grid layouts
    buttonGrid: {
      flexDirection: 'row' as const,
      flexWrap: 'wrap' as const,
      gap: spacing?.[3],
    },
    twoColumnGrid: {
      flexDirection: 'row' as const,
      flexWrap: 'wrap' as const,
      gap: spacing?.[3],
    },
    gridItem: {
      flex: 1,
      minWidth: 150,
    },

    // Badge container
    badgeRow: {
      flexDirection: 'row' as const,
      gap: spacing?.[3],
      flexWrap: 'wrap' as const,
      alignItems: 'center' as const,
    },

    // Demo containers with proper contrast
    lightBgDemo: {
      backgroundColor: colors?.light?.[100],
      padding: spacing?.[4],
      borderRadius: radius?.lg,
    },
    darkBgDemo: {
      backgroundColor: colors?.dark?.[800],
      padding: spacing?.[4],
      borderRadius: radius?.lg,
    },

    // Avatar row
    avatarRow: {
      flexDirection: 'row' as const,
      gap: spacing?.[3],
      alignItems: 'center' as const,
    },
  });

  return (
    <SafeAreaView style={dynamicStyles.container}>
      {/* Header */}
      <View style={dynamicStyles.header}>
        <Heading>Weave Design System</Heading>
        <Caption color="muted" style={dynamicStyles.headerCaption}>
          70+ Components • Mobile-First • React Native
