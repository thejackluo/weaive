}

// Helper component: Section
function Section({ title, children, spacing }: { title: string; children: React.ReactNode; spacing: any }) {
  const sectionStyles = React.useMemo(
    () =>
      StyleSheet.create({
        container: {
          gap: spacing[3],
        },
      }),
    [spacing]
  );

  return (
    <View style={sectionStyles.container}>
      <Title>{title}</Title>
      {children}
    </View>
  );
}

// Helper component: ColorSwatch
function ColorSwatch({ color, label, spacing, radius }: { color: string; label: string; spacing: any; radius: any }) {
  const swatchStyles = React.useMemo(
    () =>
      StyleSheet.create({
        container: {
          alignItems: 'center' as const,
          minWidth: 80,
        },
        colorBox: {
          width: 56,
          height: 56,
          backgroundColor: color,
          borderRadius: radius.lg,
          marginBottom: spacing[2],
        },
      }),
    [color, spacing, radius]
  );

  return (
    <View style={swatchStyles.container}>
      <View style={swatchStyles.colorBox} />
      <Caption color="muted">{label}</Caption>
    </View>
  );
}

// Main export with ThemeProvider
export default function DesignSystemShowcase() {
  return (
    <ThemeProvider>
      <ShowcaseContent />
    </ThemeProvider>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
});
