{
  "name": "weave-mobile",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "android": "expo run:android",
    "android:clean": "expo start --android --clear",
    "ios": "expo run:ios",
    "ios:clean": "expo start --ios --clear",
    "ios:pro": "expo run:ios --device \"iPhone 17 Pro\"",
    "ios:pro-max": "expo run:ios --device \"iPhone 17 Pro Max\"",
    "ios:16e": "expo run:ios --device \"iPhone 16e\"",
    "web": "expo start --web",
    "reset": "watchman watch-del-all && rm -rf node_modules && npm install && npm run start:clean",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.88.0",
    "@tanstack/react-query": "^5.90.12",
    "base-64": "^1.0.0",
    "expo": "^54.0.30",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.12",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^5.0.0-preview.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.2",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.8",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^4.1.16",
    "typescript": "~5.9.2"
  },
  "overrides": {
