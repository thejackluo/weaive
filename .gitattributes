# Normalize line endings to LF on checkin, but don't touch on checkout
# This prevents CRLF/LF issues across Windows/Mac/Linux

# Auto detect text files and normalize to LF
* text=auto eol=lf

# Explicitly set text files to LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Python files
*.py text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
.prettierrc text eol=lf
.eslintrc* text eol=lf

# Windows-specific files (keep CRLF)
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (don't touch)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.zip binary
*.gz binary
*.pdf binary
