# Test Environment Variables
# DO NOT commit actual credentials - this is a template

# Supabase Test Project (create separate project for testing)
SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_KEY=your-test-anon-key
SUPABASE_SERVICE_KEY=your-test-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-project-settings

# Database connection for migrations
DATABASE_URL=postgresql://postgres:password@db.your-test-project.supabase.co:5432/postgres

# AI Service Keys (use test/mock keys or rate-limited keys)
OPENAI_API_KEY=sk-test-key-here
ANTHROPIC_API_KEY=sk-ant-test-key-here

# AWS (if using Bedrock for testing)
AWS_ACCESS_KEY_ID=test-access-key
AWS_SECRET_ACCESS_KEY=test-secret-key
AWS_REGION=us-east-1

# Test-specific settings
TEST_MODE=true
DISABLE_RATE_LIMITING=true
