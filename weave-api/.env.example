# Environment Configuration
ENV=development

# CORS Configuration (use * for local dev, specific origins for production)
ALLOWED_ORIGINS=*

# Supabase Configuration
# Note: SUPABASE_URL should be the HTTPS API URL, not the PostgreSQL connection string
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Story 0.3: JWT Secret for verifying client tokens
# This is the JWT secret from your Supabase project settings
# Find it at: Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=

# AI Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

OAUTH=
OAUTH_SECRET=
OAUTH_CALLBACK_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=