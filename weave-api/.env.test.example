# Test Environment Configuration
# Copy this file to .env.test and fill in the values
# .env.test is gitignored and should NEVER be committed

# ===================================================================
# Local Supabase Test Database (Recommended)
# ===================================================================
# Get these credentials by running: npx supabase start
# The command will print all connection details

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<anon-key-from-npx-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-npx-supabase-start>

# Direct PostgreSQL connection (for raw SQL queries if needed)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ===================================================================
# Alternative: Separate Supabase Cloud Test Project (Fallback)
# ===================================================================
# Use this ONLY if Docker is unavailable
# Create a separate Supabase project at https://supabase.com for testing

# SUPABASE_URL=https://your-test-project.supabase.co
# SUPABASE_ANON_KEY=<anon-key-from-test-project>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-test-project>

# ===================================================================
# Environment Flag
# ===================================================================
ENVIRONMENT=test

# ===================================================================
# AI Provider Configuration (for testing AI features)
# ===================================================================
# Use mock providers for most tests to avoid API costs
# For tests that MUST use real AI, set these to test keys

OPENAI_API_KEY=mock-openai-key
ANTHROPIC_API_KEY=mock-anthropic-key

# ===================================================================
# Setup Instructions
# ===================================================================
#
# 1. Copy this file:
#    cp .env.test.example .env.test
#
# 2. Start local Supabase:
#    npx supabase start
#
# 3. Copy credentials from output to SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#
# 4. Apply migrations:
#    npx supabase db push
#
# 5. Run tests:
#    uv run pytest tests/ -v
#
# See: docs/dev/test-database-setup.md for full guide
#
