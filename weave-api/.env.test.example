# =============================================================================
# Test Environment Configuration for Weave API
# =============================================================================
# This file is used by pytest for integration tests.
# Copy this to .env.test and fill in your local Supabase credentials.
#
# Setup Instructions:
# 1. Start local Supabase: npx supabase start
# 2. Copy credentials from the output below
# 3. Paste them into this file
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Local Instance (Required for tests)
# -----------------------------------------------------------------------------
# Get these from: npx supabase status
# API URL: Usually http://127.0.0.1:54321
# Service Role Key: Long JWT token (starts with eyJ...)

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here_from_npx_supabase_start
SUPABASE_ANON_KEY=your_anon_key_here_from_npx_supabase_start

# JWT Secret (must match your Supabase JWT secret)
# Get from: npx supabase status (look for "JWT secret")
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# -----------------------------------------------------------------------------
# AI Service API Keys (Required for Story 0.9 tests)
# -----------------------------------------------------------------------------
# Google AI (Gemini) for image analysis
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenAI (optional - for fallback text AI)
OPENAI_API_KEY=your_openai_api_key_here_optional

# Anthropic (optional - for Claude AI fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here_optional

# -----------------------------------------------------------------------------
# Test Configuration
# -----------------------------------------------------------------------------
# Environment marker
ENVIRONMENT=test

# Test database connection (if needed for direct SQL access)
# Get from: npx supabase status (DB URL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Disable external services during testing (optional)
DISABLE_EXTERNAL_APIS=false

# -----------------------------------------------------------------------------
# Rate Limiting (Use lower limits for faster test execution)
# -----------------------------------------------------------------------------
RATE_LIMIT_AI_CALLS_PER_HOUR=100
RATE_LIMIT_UPLOADS_PER_DAY=50
RATE_LIMIT_COMPLETIONS_PER_DAY=200

# -----------------------------------------------------------------------------
# Storage Configuration (Local Supabase Storage)
# -----------------------------------------------------------------------------
# Storage bucket for test uploads (created by migrations)
STORAGE_BUCKET_CAPTURES=captures

# Max file upload size (10MB)
MAX_UPLOAD_SIZE_MB=10

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG

# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
# [ ] 1. Run: npx supabase start
# [ ] 2. Copy SUPABASE_URL from output
# [ ] 3. Copy SUPABASE_SERVICE_ROLE_KEY from output
# [ ] 4. Copy SUPABASE_ANON_KEY from output
# [ ] 5. Copy JWT_SECRET from output
# [ ] 6. Add GOOGLE_AI_API_KEY from https://aistudio.google.com/app/apikey
# [ ] 7. Run: uv run pytest -v
# [ ] 8. All tests should run (not skip)
# =============================================================================
