{
  "mcpServers": {
    "agentvibes": {
      "command": "npx",
      "args": [
        "-y",
        "--package=agentvibes",
        "agentvibes-mcp-server"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "get_from_https://console.upstash.com/"
      }
    },
    "ripgrep": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-ripgrep"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "PATH_TO_YOUR_PROJECT_ROOT",
        "PATH_TO_YOUR_DOCS_FOLDER"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "get_from_https://github.com/settings/tokens"
      }
    },
    "browserstack": {
      "command": "npx",
      "args": [
        "-y",
        "@browserstack/mcp-server-browserstack"
      ],
      "env": {
        "BROWSERSTACK_USERNAME": "your_browserstack_username",
        "BROWSERSTACK_ACCESS_KEY": "get_from_browserstack_account_settings"
      }
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/mcp-server-notion"
      ],
      "env": {
        "NOTION_API_KEY": "get_from_https://www.notion.so/my-integrations"
      }
    }
  }
}

