{
  "name": "@weave/design-system",
  "version": "0.1.0",
  "description": "Weave Design System - Production-ready React Native components with Tamagui-inspired architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "keywords": [
    "react-native",
    "design-system",
    "ui-components",
    "weave",
    "tamagui",
    "atomic-design",
    "typescript"
  ],
  "author": "Weave Team",
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": "^0.79.0",
    "react-native-reanimated": "^4.0.0",
    "react-native-gesture-handler": "^2.20.0"
  },
  "dependencies": {
    "react-native-svg": "^15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@storybook/react-native": "^7.6.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-native": "^0.79.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-reanimated": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/weave/weave-design-system.git"
  },
  "bugs": {
